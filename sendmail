#!/bin/bash

CONFIG_FILE="/etc/automysqlbackup/mysqlbackup.cnf"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "Configuration file not found: $CONFIG_FILE"
  exit 1
fi

CONFIG_OWNER=$(stat -c '%u' "$CONFIG_FILE")
CONFIG_MODE=$(stat -c '%a' "$CONFIG_FILE")
if [ "$CONFIG_OWNER" != "0" ] || [ "$CONFIG_MODE" != "600" ]; then
  echo "ERROR: $CONFIG_FILE must be owned by root and chmod 600. Aborting."
  exit 1
fi

source "$CONFIG_FILE"

# WARNING, LOG_FILE, ATTACHMENT_FILES duoc export tu runsqlbackup
# Neu chay doc lap, dat gia tri mac dinh de tranh loi
WARNING="${WARNING:-0}"
LOG_FILE="${LOG_FILE:-/tmp/sqlbackup_standalone.log}"
ATTACHMENT_FILES="${ATTACHMENT_FILES:-}"

is_installed() {
  command -v "$1" >/dev/null 2>&1
}

supports_mail_attach() {
  mail -A /dev/null -s "test" --version >/dev/null 2>&1
}

EMAIL_SERVICE_INSTALLED=false
if is_installed sendmail || is_installed exim4 || is_installed postfix; then
  EMAIL_SERVICE_INSTALLED=true
fi

if [ -f /etc/mailname ]; then
  HOST_MAIL=$(cat /etc/mailname)
else
  HOST_MAIL=$(hostname -f 2>/dev/null || hostname)
fi
EMAIL_FROM="noreply@${HOST_MAIL}"

if [ "$WARNING" = "1" ] && [ -n "$EMAIL_TO" ]; then
  printf "Subject: WARNING [SQL Backup]: Disk full\n\nDisk space is insufficient to perform a backup. Please free up space immediately.\n\nSystem Administrator\n" \
    | mail -s "WARNING: Disk full - SQL Backup aborted" -a "From: $EMAIL_FROM" "$EMAIL_TO"
  exit 1
fi

if [ "$EMAIL_OPTION" = "no_email" ]; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Email not sent: disabled in config." >> "$LOG_FILE"
  exit 0
fi

if [ "$EMAIL_OPTION" != "rclone" ] && { [ -z "$EMAIL_FROM" ] || [ -z "$EMAIL_TO" ]; }; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Email skipped: EMAIL_FROM or EMAIL_TO is empty." >> "$LOG_FILE"
  exit 0
fi

if [ "$EMAIL_OPTION" != "rclone" ] && ! $EMAIL_SERVICE_INSTALLED; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Email not sent: no mail service installed." >> "$LOG_FILE"
  exit 0
fi

if [ "$EMAIL_OPTION" = "attachments" ] && [ -z "$ATTACHMENT_FILES" ]; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Email not sent: no attachment files." >> "$LOG_FILE"
  exit 0
fi

MAIL_LIMIT_BYTES=10485760

if is_installed postfix; then
  MAIL_AGENT="postfix"
  MAIL_LIMIT_BYTES=$(postconf -h message_size_limit 2>/dev/null || echo 10485760)
elif is_installed exim || is_installed exim4; then
  MAIL_AGENT="exim"
elif is_installed sendmail; then
  MAIL_AGENT="sendmail"
else
  MAIL_AGENT="unknown"
fi

TOTAL_ATTACH_SIZE=0
for file in $ATTACHMENT_FILES; do
  [ -f "$file" ] && TOTAL_ATTACH_SIZE=$((TOTAL_ATTACH_SIZE + $(stat -c %s "$file")))
done

if [ "$EMAIL_OPTION" = "attachments" ] && [ "$TOTAL_ATTACH_SIZE" -gt "$MAIL_LIMIT_BYTES" ]; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Attachments too large ($((TOTAL_ATTACH_SIZE/1024/1024))MB), switching to no_attachments." >> "$LOG_FILE"
  ATTACHMENT_FILES=""
  EMAIL_OPTION="no_attachments"
fi

ATTACHMENTS=""
for file in $ATTACHMENT_FILES; do
  if [ -f "$file" ]; then
    ATTACHMENTS="$ATTACHMENTS -A $file"
  else
    echo "$(date +'%Y-%m-%d %H:%M:%S') - Attachment not found: $file" >> "$LOG_FILE"
  fi
done

SUBJECT="MySQL Backup Report - $DATE"
BODY="MySQL Backup Log - $DATE\n$(cat "$LOG_FILE")"

if [ "$EMAIL_OPTION" = "attachments" ]; then
  if supports_mail_attach && [ -n "$ATTACHMENTS" ]; then
    echo -e "$BODY" | mail -s "$SUBJECT" -a "From: $EMAIL_FROM" $ATTACHMENTS "$EMAIL_TO"
    echo "$(date +'%Y-%m-%d %H:%M:%S') - Email sent with attachments." >> "$LOG_FILE"
  elif is_installed mutt; then
    echo -e "$BODY" | mutt -s "$SUBJECT" -e "set from=\"$EMAIL_FROM\"" -a $ATTACHMENT_FILES -- "$EMAIL_TO"
    echo "$(date +'%Y-%m-%d %H:%M:%S') - Email sent with attachments via mutt." >> "$LOG_FILE"
  else
    echo "$(date +'%Y-%m-%d %H:%M:%S') - No suitable mail client for attachments." >> "$LOG_FILE"
  fi

elif [ "$EMAIL_OPTION" = "no_attachments" ]; then
  echo -e "$BODY" | mail -s "$SUBJECT" -a "From: $EMAIL_FROM" "$EMAIL_TO"
  echo "$(date +'%Y-%m-%d %H:%M:%S') - Email sent (no attachments)." >> "$LOG_FILE"

elif [ "$EMAIL_OPTION" = "rclone" ]; then
  RCLONE_REMOTE="${RCLONE_REMOTE:-gdrive}"

  if ! rclone listremotes 2>/dev/null | grep -q "^${RCLONE_REMOTE}:"; then
    echo "$(date +'%Y-%m-%d %H:%M:%S') - ERROR: rclone remote '${RCLONE_REMOTE}' not configured." >> "$LOG_FILE"
    echo "[rclone] ERROR: Remote '${RCLONE_REMOTE}' not found. Run 'rclone config'."
    exit 1
  fi

  IFS=',' read -ra SITES <<< "${RCLONE_SITES:-}"

  RCLONE_SUCCESS=0
  RCLONE_FAILED=0

  for FILE in $ATTACHMENT_FILES; do
    if [ ! -f "$FILE" ]; then
      echo "$(date +'%Y-%m-%d %H:%M:%S') - [rclone] File not found, skipping: $FILE" >> "$LOG_FILE"
      continue
    fi

    FILE_NAME=$(basename "$FILE")
    MATCHED=false

    for SITE in "${SITES[@]}"; do
      [[ "$SITE" =~ ^#.*$ ]] && continue
      SITE=$(echo "$SITE" | xargs)
      [ -z "$SITE" ] && continue

      SITE_NAME="${SITE%%.*}"
      if [[ "$FILE_NAME" == *"${SITE_NAME}"* ]]; then
        if ! rclone lsf --dirs-only "${RCLONE_REMOTE}:" 2>/dev/null | grep -q "^${SITE}/$"; then
          rclone mkdir "${RCLONE_REMOTE}:${SITE}" 2>>"$LOG_FILE"
        fi

        echo "$(date +'%Y-%m-%d %H:%M:%S') - [rclone] Uploading: $FILE_NAME -> ${RCLONE_REMOTE}:${SITE}/" >> "$LOG_FILE"
        echo "[rclone] Uploading: $FILE_NAME -> ${RCLONE_REMOTE}:${SITE}/"

        if rclone copy "$FILE" "${RCLONE_REMOTE}:${SITE}/" \
          --retries 5 \
          --low-level-retries 10 \
          --timeout 10m \
          --transfers 1 \
          2>>"$LOG_FILE"; then
          echo "$(date +'%Y-%m-%d %H:%M:%S') - [rclone] Upload OK: $FILE_NAME" >> "$LOG_FILE"
          RCLONE_SUCCESS=$((RCLONE_SUCCESS + 1))
        else
          echo "$(date +'%Y-%m-%d %H:%M:%S') - [rclone] Upload FAILED: $FILE_NAME" >> "$LOG_FILE"
          RCLONE_FAILED=$((RCLONE_FAILED + 1))
        fi

        MATCHED=true
        break
      fi
    done

    if [ "$MATCHED" = false ]; then
      echo "$(date +'%Y-%m-%d %H:%M:%S') - [rclone] WARNING: No matching site for: $FILE_NAME" >> "$LOG_FILE"
      echo "[rclone] WARNING: No matching site for: $FILE_NAME"
    fi
  done

  if [ -n "$EMAIL_TO" ] && $EMAIL_SERVICE_INSTALLED; then
    RCLONE_SUMMARY="Rclone upload: $RCLONE_SUCCESS success, $RCLONE_FAILED failed."
    echo -e "$BODY\n\n$RCLONE_SUMMARY" | mail -s "$SUBJECT" -a "From: $EMAIL_FROM" "$EMAIL_TO"
    echo "$(date +'%Y-%m-%d %H:%M:%S') - Email notification sent after rclone upload." >> "$LOG_FILE"
  fi

  echo "$(date +'%Y-%m-%d %H:%M:%S') - Rclone done. Success: $RCLONE_SUCCESS, Failed: $RCLONE_FAILED." >> "$LOG_FILE"
  echo "Rclone done. Success: $RCLONE_SUCCESS, Failed: $RCLONE_FAILED."
fi
