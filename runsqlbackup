#!/bin/bash

CONFIG_DIR="/etc/automysqlbackup"
CONFIG_FILE="${CONFIG_DIR}/mysqlbackup.cnf"
CONFIG_MAIL="${CONFIG_DIR}/sendmail"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "Configuration file not found: $CONFIG_FILE"
  exit 1
fi

# Tolak neu config co the bi viet boi bat ky ai khac ngoai root
CONFIG_OWNER=$(stat -c '%u' "$CONFIG_FILE")
CONFIG_MODE=$(stat -c '%a' "$CONFIG_FILE")
if [ "$CONFIG_OWNER" != "0" ] || [ "$CONFIG_MODE" != "600" ]; then
  echo "ERROR: $CONFIG_FILE must be owned by root and chmod 600. Aborting."
  exit 1
fi

source "$CONFIG_FILE"

mkdir -p "$BACKUP_DIR"

DATE=$(date +%d-%m-%Y)
DAY_NAME=$(date +%A)
DAY_OF_WEEK=$(date +%u)

LOG_DIR="$BACKUP_DIR/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/backup_log_$DATE.log"
export LOG_FILE

export MYSQL_PWD="$MYSQL_PASSWORD"

IGNORE_TABLES="itsec_logs itsec_temp itsec_lockouts itsec_distributed_storage itsec_opaque_tokens itsec_geolocation_cache"

DATABASES=$(mysql -u"$MYSQL_USER" -e "SHOW DATABASES;" 2>/dev/null | grep -Ev "(Database|$CONFIG_DB_EXCLUDE)")

log_notice() {
  echo "$1"
  echo -e "$1" >> "$LOG_FILE"
}

WARNING=0
export WARNING
TOTAL_BACKUP_SIZE=0
TOTAL_BACKUP_SIZE_MB=0
FREE_DISK_SPACE=0
FREE_DISK_SPACE_MB=0

check_backup_disk_space() {
  for DB in $DATABASES; do
    TABLE_SIZES=$(mysql -u"$MYSQL_USER" -N -e \
      "SELECT COALESCE(SUM(Data_length + Index_length), 0) FROM information_schema.TABLES WHERE table_schema='$DB';" \
      2>/dev/null | awk '{print $1+0}')
    TOTAL_BACKUP_SIZE=$((TOTAL_BACKUP_SIZE + TABLE_SIZES))
  done

  TOTAL_BACKUP_SIZE_MB=$((TOTAL_BACKUP_SIZE / 1024 / 1024))

  # Uoc tinh nen 50% - conservative de tranh bao sai khi disk thuc su day
  TOTAL_BACKUP_SIZE_MB=$((TOTAL_BACKUP_SIZE_MB / 2))

  FREE_DISK_SPACE=$(df -BG "$BACKUP_DIR" | awk 'NR==2 {print $4}' | tr -d 'G')
  FREE_DISK_SPACE_MB=$((FREE_DISK_SPACE * 1024))

  if [ "$TOTAL_BACKUP_SIZE_MB" -gt "$FREE_DISK_SPACE_MB" ]; then
    echo "WARNING: Not enough disk space to perform backup."
    echo "$(date +'%Y-%m-%d %H:%M:%S') - WARNING: Not enough disk space." >> "$LOG_FILE"
    if [ -f "$CONFIG_MAIL" ]; then
      WARNING=1
      export WARNING
      source "$CONFIG_MAIL"
    else
      log_notice "Mail not sent: config file not found: $CONFIG_MAIL"
    fi
    exit 1
  fi
}

check_backup_disk_space

if [ -z "$DATABASES" ]; then
  echo "$(date +'%Y-%m-%d %H:%M:%S') - No databases found to backup." >> "$LOG_FILE"
  exit 1
fi

for dir in daily weekly monthly; do
  mkdir -p "$BACKUP_DIR/$dir" 2>> "$LOG_FILE" || {
    echo "$(date +'%Y-%m-%d %H:%M:%S') - Failed to create $dir backup directory" >> "$LOG_FILE"
    exit 1
  }
done

SUCCESSFUL_BACKUPS=""
FAILED_BACKUPS=""
ATTACHMENT_FILES=""

backup_databases() {
  local backup_dir="$1"
  local backup_type="$2"

  echo "Database Backup on $(date +'%Y-%m-%d') - Initiating..."
  echo ""
  echo "" >> "$LOG_FILE"
  echo "=== Auto Backup SQL $(date +'%Y-%m-%d') ======================================" >> "$LOG_FILE"

  for DB in $DATABASES; do
    DB_BACKUP_DIR="$backup_dir/$DB"
    mkdir -p "$DB_BACKUP_DIR"

    BACKUP_FILE="$DB_BACKUP_DIR/${DATE}_${DB}_${DAY_NAME}.sql.gz"

    IGNORE_TABLE_PARAMS=""
    ALL_TABLES=$(mysql -u"$MYSQL_USER" "$DB" -e "SHOW TABLES;" 2>/dev/null | tail -n +2)

    for IGNORE_TABLE in $IGNORE_TABLES; do
      for TABLE in $ALL_TABLES; do
        if [[ "$TABLE" == *"$IGNORE_TABLE" ]]; then
          IGNORE_TABLE_PARAMS="$IGNORE_TABLE_PARAMS --ignore-table=${DB}.${TABLE}"
        fi
      done
    done

    if mysqldump -u"$MYSQL_USER" $IGNORE_TABLE_PARAMS "$DB" 2>>"$LOG_FILE" | gzip > "$BACKUP_FILE"; then
      if [ -s "$BACKUP_FILE" ]; then
        SUCCESSFUL_BACKUPS="$SUCCESSFUL_BACKUPS\n[$backup_type] $BACKUP_FILE"

        if [[ "$backup_type" == "Daily" && "$backup_dir" == "$BACKUP_DIR/daily" ]]; then
          ATTACHMENT_FILES="$ATTACHMENT_FILES $BACKUP_FILE"
        fi

        echo "$(date +'%H:%M:%S') - [$backup_type] $DB -> $BACKUP_FILE"
        echo "$(date +'%Y-%m-%d %H:%M:%S') - [$backup_type] $DB -> $BACKUP_FILE" >> "$LOG_FILE"

        [ -n "$IGNORE_TABLE_PARAMS" ] && \
          echo "$(date +'%Y-%m-%d %H:%M:%S') -   Ignored tables: $IGNORE_TABLE_PARAMS" >> "$LOG_FILE"
      else
        FAILED_BACKUPS="$FAILED_BACKUPS\n[$backup_type] $DB - Empty backup file"
        echo "$(date +'%Y-%m-%d %H:%M:%S') - [$backup_type] Backup failed: $DB (empty file)" >> "$LOG_FILE"
        rm -f "$BACKUP_FILE"
      fi
    else
      FAILED_BACKUPS="$FAILED_BACKUPS\n[$backup_type] $DB - Backup failed"
      echo "$(date +'%Y-%m-%d %H:%M:%S') - [$backup_type] Backup failed: $DB" >> "$LOG_FILE"
    fi
  done
}

backup_databases "$BACKUP_DIR/daily" "Daily"

if [ "$DAY_OF_WEEK" -eq 6 ]; then
  backup_databases "$BACKUP_DIR/weekly" "Weekly"
fi

LAST_DAY_OF_MONTH=$(date -d "$(date +%Y-%m-01) +1 month -1 day" +%d)
if [ "$(date +%d)" -eq "$LAST_DAY_OF_MONTH" ]; then
  backup_databases "$BACKUP_DIR/monthly" "Monthly"
fi

cleanup_old_backups() {
  local dir="$1"
  local days="$2"
  local notice="Cleanup: $dir (older than $days days)"

  echo ""
  echo "$notice"
  echo "" >> "$LOG_FILE"
  echo "$notice" >> "$LOG_FILE"

  local old_files
  old_files=$(find "$dir" -type f -mtime +"$days")

  if [ -n "$old_files" ]; then
    echo "$old_files" >> "$LOG_FILE"
    find "$dir" -type f -mtime +"$days" -exec rm -v {} \;
  else
    echo "No old files found in $dir."
    echo "$(date +'%Y-%m-%d %H:%M:%S') - No old files found in $dir." >> "$LOG_FILE"
  fi
}

cleanup_old_backups "$BACKUP_DIR/daily"   30
cleanup_old_backups "$BACKUP_DIR/weekly"  84
cleanup_old_backups "$BACKUP_DIR/monthly" 365

echo ""
echo "Log written to: $LOG_FILE"

# Set permissions cho toan bo backup dir bat ke custom hay default
chown -R root:root "$BACKUP_DIR"
find "$BACKUP_DIR" -type f -exec chmod 400 {} \;
find "$BACKUP_DIR" -type d -exec chmod 700 {} \;
# Log can ghi them, tra lai quyen write cho log dir
chmod 700 "$LOG_DIR"

TOTAL_DATABASES=$(echo "$DATABASES" | grep -c '[^[:space:]]' 2>/dev/null || echo 0)
TOTAL_SUCCESS=$(echo -e "$SUCCESSFUL_BACKUPS" | grep -c ".sql.gz" 2>/dev/null || echo 0)
TOTAL_FAILED=$(echo -e "$FAILED_BACKUPS" | grep -c "Backup failed" 2>/dev/null || echo 0)

log_notice ""
log_notice "Summary:"
log_notice "$(date +'%Y-%m-%d %H:%M:%S') - Total databases: $TOTAL_DATABASES"
log_notice "$(date +'%Y-%m-%d %H:%M:%S') - Successful backups: $TOTAL_SUCCESS"
log_notice "$(date +'%Y-%m-%d %H:%M:%S') - Failed backups: $TOTAL_FAILED"
log_notice "$(date +'%Y-%m-%d %H:%M:%S') - Estimated backup size: ${TOTAL_BACKUP_SIZE_MB}MB"
log_notice "$(date +'%Y-%m-%d %H:%M:%S') - Remaining disk space: $((FREE_DISK_SPACE_MB - TOTAL_BACKUP_SIZE_MB))MB"

export ATTACHMENT_FILES

if [ -f "$CONFIG_MAIL" ]; then
  source "$CONFIG_MAIL"
else
  log_notice ""
  log_notice "Mail not sent: config file not found: $CONFIG_MAIL"
fi

find "$LOG_DIR" -type f -name "*.log" -mtime +60 -exec rm -v {} \; >> "$LOG_FILE"
