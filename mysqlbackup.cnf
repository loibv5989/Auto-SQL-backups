BACKUP_DIR="/var/backups/db"

MYSQL_USER="root"

MYSQL_PASSWORD=""

CONFIG_DB_EXCLUDE="mysql|information_schema|performance_schema|sys|test"

# attachments | no_attachments | no_email | rclone
EMAIL_OPTION="no_attachments"

SENDER_NAME="Admin"

EMAIL_TO=""

RCLONE_REMOTE="gdrive"

# Comma-separated list of folder names ON Google Drive to upload backups into.
# Each name is a custom label you define — not a domain. E.g: nbblo,myproject,client-abc
RCLONE_SITES=""
